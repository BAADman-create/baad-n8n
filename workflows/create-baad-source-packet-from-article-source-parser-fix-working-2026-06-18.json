      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const source = $json.fields || {};\n\nconst sourceRecordId = $json.id;\nconst articleIds = source['Articles'] || [];\n\nconst sourceBody = String(source['Source Body'] || '').trim();\nconst sourceOutlet = String(source['Source Outlet'] || '').trim();\nconst sourceTitle = String(source['Source Title'] || '').trim();\nconst sourceUrl = String(source['Source URL'] || '').trim();\n\nconst words = sourceBody\n  .replace(/\\s+/g, ' ')\n  .trim()\n  .split(' ')\n  .filter(Boolean);\n\nconst wordCount = sourceBody ? words.length : 0;\n\nconst lower = sourceBody.toLowerCase();\n\nfunction hasAny(terms) {\n  return terms.some((term) => lower.includes(term));\n}\n\nconst hasExhibitionSignal = hasAny([\n  'exhibition',\n  'solo exhibition',\n  'group exhibition',\n  'gallery',\n  'museum',\n  'on view',\n  'presented by',\n  'venue',\n]);\n\nconst hasFilmSignal = hasAny([\n  'film',\n  'documentary',\n  'video',\n  'screening',\n  'art21',\n  'cinema',\n  'episode',\n  'platform',\n]);\n\nconst hasMaterialSignal = hasAny([\n  'material',\n  'process',\n  'rubber',\n  'metal',\n  'textile',\n  'ceramic',\n  'paint',\n  'bronze',\n  'wood',\n  'sculpture',\n]);\n\nconst hasQuoteSignal = /“[^”]+”|\"[^\"]+\"/.test(sourceBody);\n\nlet likelyArticleType = 'Other / Needs Classification';\nlet draftUsePriority = 'Primary';\nlet sourceType = 'Additional Article';\n\nif (hasExhibitionSignal) {\n  likelyArticleType = 'Exhibition / Project Spotlight';\n  sourceType = sourceOutlet.toLowerCase().includes('gallery')\n    ? 'Gallery Exhibition Page'\n    : 'Gallery Press Release';\n}\n\nif (hasFilmSignal) {\n  likelyArticleType = 'Film / Media Story';\n  sourceType = 'Additional Article';\n}\n\nif (hasMaterialSignal && !hasFilmSignal) {\n  likelyArticleType = hasExhibitionSignal\n    ? 'Exhibition / Project Spotlight'\n    : 'Material / Process Story';\n}\n\nlet sourceReliability = 'Unknown';\nif (\n  sourceOutlet &&\n  hasAny(['gallery', 'museum', 'institution', 'foundation']) ||\n  sourceOutlet.toLowerCase().includes('moffett')\n) {\n  sourceReliability = 'High';\n}\n\nlet rightsRisk = 'Medium';\nif (\n  sourceType === 'Gallery Press Release' ||\n  sourceType === 'Gallery Exhibition Page' ||\n  sourceType === 'Museum Page' ||\n  sourceType === 'Institution Page'\n) {\n  rightsRisk = 'Medium';\n}\n\nlet sourceQualityStatus = 'Needs Review';\nlet sourceStrengthScore = 0;\nconst sourceStrengthNotes = [];\n\nif (wordCount >= 500) {\n  sourceStrengthScore += 3;\n  sourceStrengthNotes.push('Strong source length.');\n} else if (wordCount >= 200) {\n  sourceStrengthScore += 2;\n  sourceStrengthNotes.push('Usable source length.');\n} else if (wordCount >= 80) {\n  sourceStrengthScore += 1;\n  sourceStrengthNotes.push('Short but usable for packet creation.');\n} else {\n  sourceStrengthNotes.push('Source is very short.');\n}\n\nif (hasExhibitionSignal) {\n  sourceStrengthScore += 1;\n  sourceStrengthNotes.push('Exhibition/project signals detected.');\n}\n\nif (hasFilmSignal) {\n  sourceStrengthScore += 1;\n  sourceStrengthNotes.push('Film/media signals detected.');\n}\n\nif (hasMaterialSignal) {\n  sourceStrengthScore += 1;\n  sourceStrengthNotes.push('Material/process signals detected.');\n}\n\nif (hasQuoteSignal) {\n  sourceStrengthScore += 1;\n  sourceStrengthNotes.push('Potential quote language detected.');\n}\n\nif (sourceStrengthScore >= 5) {\n  sourceQualityStatus = 'Strong';\n} else if (sourceStrengthScore >= 3) {\n  sourceQualityStatus = 'Usable';\n} else {\n  sourceQualityStatus = 'Needs More Source';\n}\n\nconst packetJson = {\n  sourceRecordId,\n  articleIds,\n  sourceOutlet,\n  sourceTitle,\n  sourceUrl,\n  wordCount,\n  likelyArticleType,\n  sourceType,\n  sourceReliability,\n  rightsRisk,\n  sourceQualityStatus,\n  sourceStrengthScore,\n  sourceStrengthNotes,\n  automationNote:\n    'Created from Article Sources manual pasted text. Draft generation remains blocked until human approval.',\n};\n\nconst packetNameParts = [\n  sourceOutlet || 'Unknown Source',\n  sourceTitle || 'Untitled Source',\n];\n\nconst packetName = packetNameParts.join(' — ');\n\nconst promptReadyExtract = [\n  `SOURCE OUTLET: ${sourceOutlet || 'Unknown'}`,\n  `SOURCE TITLE: ${sourceTitle || 'Untitled'}`,\n  `SOURCE URL: ${sourceUrl || 'Not provided'}`,\n  `LIKELY ARTICLE TYPE: ${likelyArticleType}`,\n  `SOURCE QUALITY: ${sourceQualityStatus}`,\n  '',\n  'SOURCE TEXT:',\n  sourceBody,\n].join('\\n');\n\nreturn {\n  sourceRecordId,\n  articleIds,\n  sourceOutlet,\n  sourceTitle,\n  sourceUrl,\n  sourceBody,\n  wordCount,\n  packetName,\n  sourceType,\n  likelyArticleType,\n  draftUsePriority,\n  sourceReliability,\n  rightsRisk,\n  sourceQualityStatus,\n  sourceStrengthScore,\n  sourceStrengthNotes: sourceStrengthNotes.join(' '),\n  promptReadyExtract,\n  packetJson: JSON.stringify(packetJson, null, 2),\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
