    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $('Prepare Source Packet Payload').item.json;\n\nconst output = $json.output;\nlet text = '';\n\nif (Array.isArray(output)) {\n  const message = output.find(o => o.type === 'message') || output[0];\n  const content = message?.content || [];\n\n  const textPart = Array.isArray(content)\n    ? content.find(c => c.type === 'output_text') || content[0]\n    : null;\n\n  text = textPart?.text || '';\n}\n\nif (!text && typeof $json.text === 'string') {\n  text = $json.text;\n}\n\nif (!text && typeof $json.output === 'string') {\n  text = $json.output;\n}\n\nif (!text) {\n  throw new Error('Could not find OpenAI output text.');\n}\n\ntext = text.trim();\n\n// Remove accidental markdown fences if the model ever adds them.\ntext = text\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/```$/i, '')\n  .trim();\n\nlet analysis;\n\ntry {\n  analysis = JSON.parse(text);\n} catch (err) {\n  throw new Error(`Could not parse OpenAI JSON: ${err.message}\\n\\nRaw text:\\n${text}`);\n}\n\nfunction formatObject(item) {\n  if (!item || typeof item !== 'object') return String(item || '');\n\n  if (item.quote || item.speaker || item.useNote) {\n    return [\n      item.quote ? `Quote: ${item.quote}` : '',\n      item.speaker ? `Speaker: ${item.speaker}` : '',\n      item.useNote ? `Use note: ${item.useNote}` : '',\n    ].filter(Boolean).join('\\n');\n  }\n\n  return Object.entries(item)\n    .map(([key, value]) => {\n      const formattedValue = Array.isArray(value)\n        ? value.join(', ')\n        : value === null || value === undefined\n          ? ''\n          : String(value);\n\n      return `${key}: ${formattedValue}`;\n    })\n    .join('\\n');\n}\n\nfunction asText(value) {\n  if (Array.isArray(value)) {\n    return value\n      .map((item) => {\n        if (item && typeof item === 'object') return formatObject(item);\n        if (item === null || item === undefined) return '';\n        return String(item);\n      })\n      .filter(Boolean)\n      .join('\\n\\n');\n  }\n\n  if (value && typeof value === 'object') return formatObject(value);\n  if (value === null || value === undefined) return '';\n  return String(value);\n}\n\nfunction bool(value) {\n  return value === true || value === 'true';\n}\n\nconst mergedPacketJson = {\n  ...(original.packetJson ? JSON.parse(original.packetJson) : {}),\n  openAiAnalysis: analysis,\n};\n\nreturn {\n  ...original,\n\n  aiShortSourceSummary: asText(analysis.shortSourceSummary),\n  aiVerifiedFacts: asText(analysis.verifiedFacts),\n  aiQuoteCandidates: asText(analysis.quoteCandidates),\n  aiQuoteUseNotes: asText(analysis.quoteUseNotes),\n  aiSourceMeaningToRecast: asText(analysis.sourceMeaningToRecast),\n  aiAvoidCopyingNotes: asText(analysis.avoidCopyingNotes),\n  aiEditorialUseNotes: asText(analysis.editorialUseNotes),\n  aiPromptReadyExtract: asText(analysis.promptReadyExtract),\n\n  aiRecommendedArticleType: asText(analysis.recommendedArticleType),\n  aiRecommendedBAADAngle: asText(analysis.recommendedBAADAngle),\n  aiSourceStrength: asText(analysis.sourceStrength),\n  aiSourceQualityStatus: asText(analysis.sourceQualityStatus),\n  aiSourceReliability: asText(analysis.sourceReliability),\n  aiRightsCopyingRisk: asText(analysis.rightsCopyingRisk),\n\n  aiHumanReviewNeeded: bool(analysis.humanReviewNeeded),\n  aiHumanReviewNotes: asText(analysis.humanReviewNotes),\n  aiNeedsMoreSourceMaterial: bool(analysis.needsMoreSourceMaterial),\n  aiSuggestedAdditionalSources: asText(analysis.suggestedAdditionalSources),\n  aiUnsupportedClaimWarnings: asText(analysis.unsupportedClaimWarnings),\n\n  packetJson: JSON.stringify(mergedPacketJson, null, 2),\n};"
